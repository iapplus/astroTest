---
const categories = [
  { id: 'FAQ', label: 'FAQ', icon: '❓' },
  { id: 'Features', label: 'Features', icon: '✨' },
  { id: 'How To Install', label: 'How To Install', icon: '🔧' },
  { id: 'Installation Requirements', label: 'Installation Requirements', icon: '📋' },
  { id: 'Troubleshooting', label: 'Troubleshooting', icon: '🔍' },
];

const categoryArticles = {
  'FAQ': [
    { title: 'How to connect Wi-Fi Gateway', slug: 'wifi-gateway/FAQ/how-to-connect' },
    { title: 'Troubleshooting connection issues', slug: 'wifi-gateway/FAQ/troubleshooting-connection' },
  ],
  'Features': [
    { title: 'Wireless Connectivity', slug: 'wifi-gateway/Features/wireless-connectivity' },
    { title: 'Remote Control', slug: 'wifi-gateway/Features/remote-control' },
  ],
  'How To Install': [
    { title: 'Step-by-Step Installation', slug: 'wifi-gateway/How To Install/step-by-step' },
  ],
  'Installation Requirements': [
    { title: 'Wi-Fi Requirements', slug: 'wifi-gateway/Installation Requirements/wifi-requirements' },
  ],
  'Troubleshooting': [
    { title: 'LED Indicators', slug: 'wifi-gateway/Troubleshooting/led-indicators' },
  ],
};

const urlParams = new URLSearchParams(Astro.url.search);
const activeCategory = urlParams.get('category') || 'FAQ';
const activeDocs = categoryArticles[activeCategory as keyof typeof categoryArticles] || [];
---

<style is:global>
  /* 隐藏所有侧边栏元素 */
  body[data-homepage] aside,
  body[data-homepage] .sidebar,
  body[data-homepage] .left-sidebar,
  body[data-homepage] .right-sidebar,
  body[data-homepage] nav[aria-label="Main navigation"],
  body[data-homepage] nav[aria-label="Table of contents"] {
    display: none !important;
  }

  /* 让主内容占满整个宽度 */
  body[data-homepage] main {
    grid-template-columns: 1fr !important;
  }
</style>

<style>
  .page-wrapper {
    max-width: 1200px;
    margin: 0 auto;
    padding: 60px 24px;
  }

  .category-nav {
    display: flex;
    gap: 16px;
    justify-content: center;
    margin-bottom: 48px;
    flex-wrap: wrap;
  }

  .category-item {
    padding: 16px 32px;
    border: 2px solid #e0e0e0;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.3s ease;
    background: #fff;
    text-align: center;
    min-width: 140px;
    text-decoration: none;
    color: inherit;
  }

  .category-item:hover {
    border-color: #0094dd;
    color: #0094dd;
  }

  .category-item.active {
    border-color: #0094dd;
    background: #0094dd;
    color: #fff;
  }

  .category-icon {
    font-size: 32px;
    margin-bottom: 8px;
  }

  .category-label {
    font-size: 14px;
    font-weight: 500;
  }

  .articles-section {
    background: #fff;
    border-radius: 8px;
    padding: 32px;
  }

  .articles-title {
    font-size: 24px;
    font-weight: 600;
    margin-bottom: 24px;
    color: #222;
    text-align: center;
  }

  .articles-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .article-item {
    border-bottom: 1px solid #f0f0f0;
  }

  .article-item:last-child {
    border-bottom: none;
  }

  .article-link {
    display: block;
    padding: 16px 0;
    color: #222;
    text-decoration: none;
    font-size: 16px;
    transition: color 0.3s ease;
  }

  .article-link:hover {
    color: #0094dd;
  }

  .no-articles {
    color: #999;
    text-align: center;
    padding: 40px 0;
  }
</style>

<div class="page-wrapper">
  <div class="category-nav">
    {categories.map((category) => (
      <a 
        href={`/wifi-gateway/?category=${encodeURIComponent(category.id)}`}
        class={`category-item ${activeCategory === category.id ? 'active' : ''}`}
      >
        <div class="category-icon">{category.icon}</div>
        <div class="category-label">{category.label}</div>
      </a>
    ))}
  </div>

  <div class="articles-section">
    <div class="articles-title">{activeCategory}</div>
    {activeDocs.length > 0 ? (
      <ul class="articles-list">
        {activeDocs.map((doc) => (
          <li class="article-item">
            <a href={`/${doc.slug}`} class="article-link">
              {doc.title}
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <div class="no-articles">暂无文章</div>
    )}
  </div>
</div>
