---
interface Props {
  from?: string;
  to?: string;
}

const { 
  from = "#0094dd", 
  to = "#00d4ff"
} = Astro.props;
---

<span 
  style={`
    background-image: linear-gradient(120deg, ${from} 0%, ${to} 100%);
    background-repeat: no-repeat;
    background-size: 100% 2px;
    background-position: 0 100%;
    padding-bottom: 4px;
  `}
>
  <slot />
</span>
