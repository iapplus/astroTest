<style is:global>
  #footer-bar {
    width: 100%;
    background-color: #fff;
    display: flex;
    flex-direction: column;
    justify-content: space-around;
    justify-content: center;
    padding: 16px 0;
  }

  @media (min-width: 768px) {
    #footer-bar {
      flex-direction: row;
    }
  }

  #footer-bar .py-3 {
    padding: 12px 0;
  }

  #footer-bar .px-2 {
    padding: 0 8px;
  }

  #footer-bar .footer-logo {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  #footer-bar .footer-logo img {
    display: block;
  }

  #footer-bar .footer-column {
    display: flex;
    flex-direction: column;
    padding: 12px 12px;
  }

  #footer-bar .footer-header {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
  }

  #footer-bar .footer-title {
    letter-spacing: .3em;
    text-transform: uppercase;
    justify-content: center;
    display: flex;
    flex: 1;
  }

  #footer-bar .footer-item-arrow {
    display: none;
    cursor: pointer;
  }

  @media (max-width: 767px) {
    #footer-bar .footer-item-arrow {
      display: block;
    }
  }

  #footer-bar .footer-item-arrow .icon {
    width: 1.2rem;
    height: 1.2rem;
  }

  #footer-bar .footer-links {
    display: flex;
    flex-direction: column;
    text-align: center;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  @media (max-width: 767px) {
    #footer-bar .footer-links {
      display: none;
    }
  }

  #footer-bar .footer-links li {
    margin: 4px 0;
  }

  #footer-bar .footer-links a {
    text-decoration: none;
    color: #666;
  }

  #footer-bar .footer-links a:hover {
    color: #0094dd;
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    const footers = document.querySelectorAll('#footer-bar .footer-header');
    footers.forEach(function(header) {
      header.addEventListener('click', function() {
        const links = this.parentElement.querySelector('.footer-links');
        if (links) {
          links.style.display = links.style.display === 'none' || links.style.display === '' ? 'flex' : 'none';
        }
      });
    });
  });
</script>
