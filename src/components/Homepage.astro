          <rect x="43" y="55" width="14" height="25" rx="1" fill="#333"/>
          <circle cx="46" cy="58" r="1.5" fill="#fff"/>
          <circle cx="50" cy="58" r="1.5" fill="#fff"/>
          <circle cx="54" cy="58" r="1.5" fill="#fff"/>
          <circle cx="46" cy="62" r="1.5" fill="#fff"/>
          <circle cx="50" cy="62" r="1.5" fill="#fff"/>
          <circle cx="54" cy="62" r="1.5" fill="#fff"/>
          <circle cx="46" cy="66" r="1.5" fill="#fff"/>
          <circle cx="50" cy="66" r="1.5" fill="#fff"/>
          <circle cx="54" cy="66" r="1.5" fill="#fff"/>
          <circle cx="46" cy="70" r="1.5" fill="#fff"/>
          <circle cx="50" cy="70" r="1.5" fill="#fff"/>
          <circle cx="54" cy="70" r="1.5" fill="#fff"/>
