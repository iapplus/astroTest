    <div class="product-card">
      <div class="product-icon">
        <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect x="35" y="20" width="30" height="60" rx="8" fill="#1a1a1a" stroke="#333" stroke-width="2"/>
          <rect x="45" y="10" width="10" height="12" rx="2" fill="#333"/>
